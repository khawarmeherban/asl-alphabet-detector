# Environment Variables Template for ASL Alphabet Detector
# 
# Copy this file to .env.local and fill in your actual values
# IMPORTANT: Never commit .env.local to version control

# ==============================================
# Backend API Configuration
# ==============================================

# Development (local Flask server)
# REACT_APP_API_URL=http://localhost:7860

# Production / deployed backend
# Example Hugging Face Space custom subdomain:
REACT_APP_API_URL=https://khawar26-asl-backend.hf.space

# ==============================================
# Application Configuration
# ==============================================

# Application name
REACT_APP_NAME=ASL Alphabet Detector

# Version
REACT_APP_VERSION=2.0.0

# Environment
REACT_APP_ENV=production

# ==============================================
# Feature Flags
# ==============================================

# Enable/disable features
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_VOICE=true
REACT_APP_ENABLE_GESTURE_CONTROL=true
REACT_APP_ENABLE_OFFLINE_MODE=true

# ==============================================
# API Keys (if needed for future integrations)
# ==============================================

# Google Analytics (optional)
# REACT_APP_GA_TRACKING_ID=UA-XXXXXXXXX-X

# Sentry Error Tracking (optional)
# REACT_APP_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ==============================================
# Performance Configuration
# ==============================================

# Prediction throttle (milliseconds)
REACT_APP_PREDICTION_THROTTLE=100

# Buffer size for prediction stabilization
REACT_APP_PREDICTION_BUFFER_SIZE=8

# Confidence threshold (0.0 to 1.0)
REACT_APP_CONFIDENCE_THRESHOLD=0.5

# ==============================================
# Debug Configuration
# ==============================================

# Enable debug mode
REACT_APP_DEBUG=false

# Enable verbose logging
REACT_APP_VERBOSE_LOGGING=false
